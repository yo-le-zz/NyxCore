# NyxCore Server — environment configuration
# Copy this file to .env and fill in the values.

# ── REQUIRED ──────────────────────────────────────────────────────────────────
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_SECRET
MASTER_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD

# ── Network ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Comma-separated list of allowed CORS origins (use * for dev only)
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Storage ───────────────────────────────────────────────────────────────────
ISO_STORAGE_PATH=/var/lib/nyxcore/isos
MAX_UPLOAD_SIZE_MB=8192
DISK_ALERT_THRESHOLD_PCT=90

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./nyxcore.db

# ── Debug (disable in production) ───────────────────────────────────────────
DEBUG=false
